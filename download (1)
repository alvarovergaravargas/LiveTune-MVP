export type GenreKey =
  | "lofi"
  | "jazz"
  | "ambient"
  | "classical"
  | "synthwave"
  | "worship"
  | "latin"
  | "study";

export type MoodKey = "focus" | "relax" | "energy" | "sleep";

export const genres: Array<{ key: GenreKey; label: string; terms: string[] }> = [
  { key: "lofi", label: "Lo-fi", terms: ["lofi live radio", "lofi hip hop live", "beats to study live"] },
  { key: "jazz", label: "Jazz", terms: ["jazz live radio", "coffee jazz live", "smooth jazz live"] },
  { key: "ambient", label: "Ambient", terms: ["ambient music live", "space ambient live", "meditation music live"] },
  { key: "classical", label: "Classical", terms: ["classical music live", "piano classical live", "orchestra music live"] },
  { key: "synthwave", label: "Synthwave", terms: ["synthwave live radio", "retrowave live", "cyberpunk music live"] },
  { key: "worship", label: "Worship", terms: ["worship music live", "christian music live", "adoration music live"] },
  { key: "latin", label: "Latin Chill", terms: ["latin chill live", "latin music live radio", "bossa nova live"] },
  { key: "study", label: "Study", terms: ["study music live", "focus music live", "deep work music live"] },
];

export const moods: Array<{ key: MoodKey; label: string; queryBoost: string }> = [
  { key: "focus", label: "Focus", queryBoost: "focus study work" },
  { key: "relax", label: "Relax", queryBoost: "relax calm chill" },
  { key: "energy", label: "Energy", queryBoost: "upbeat energy" },
  { key: "sleep", label: "Sleep", queryBoost: "sleep calm soft" },
];

export function buildQuery(genre: GenreKey, mood: MoodKey) {
  const selectedGenre = genres.find((item) => item.key === genre) ?? genres[0];
  const selectedMood = moods.find((item) => item.key === mood) ?? moods[0];
  const baseTerm = selectedGenre.terms[Math.floor(Math.random() * selectedGenre.terms.length)];
  return `${baseTerm} ${selectedMood.queryBoost}`;
}
